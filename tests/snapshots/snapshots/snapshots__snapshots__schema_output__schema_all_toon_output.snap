                    - type: "null"
                required[1]: holder
            required[2]: state,detail
          - description: A matching reservation exists but is no longer active.
            type: object
            properties:
              state:
                type: string
                const: expired
              detail:
                type: object
                properties:
                  holder.type: string
                  released_at:
                    type[2]: string,"null"
                    format: date-time
                  provenance.anyOf[2]:
                    - "$ref": #/$defs/ReservationEvidenceProvenance
                    - type: "null"
                required[1]: holder
            required[2]: state,detail
          - description: Snapshot data was supplied but could not be trusted.
            type: object
            properties:
              state:
                type: string
                const: invalid_snapshot
              detail:
                type: object
                properties.reason.type: string
                required[1]: reason
            required[2]: state,detail
      ReservationEvidenceProvenance:
        description: Provenance copied from a matching reservation snapshot.
        type: object
        properties:
          path_pattern.type: string
          exclusive.type: boolean
          reason.type[2]: string,"null"
          expires_ts:
            type: string
            format: date-time
          released_ts:
            type[2]: string,"null"
            format: date-time
          thread_id.type[2]: string,"null"
          matched_on:
            type: array
            items:
              "$ref": #/$defs/ReservationSnapshotMatchReason
        required[4]: path_pattern,exclusive,expires_ts,matched_on
      ReservationSnapshotMatchReason:
        description: Why an Agent Mail reservation snapshot was associated with an issue.
        oneOf[3]{description,type,const}:
          Reservation holder matches the issue assignee.,string,holder_matches_assignee
          Reservation reason or thread id names the issue id.,string,issue_id
          A recent issue comment names the reservation path pattern.,string,comment_path
      ClaimClassification:
        description: Stable claim classifications used by coordination-aware surfaces.
        oneOf[7]{description,type,const}:
          The issue is in progress but has no meaningful assignee.,string,unassigned
          The claim is still within the owner-specific freshness window.,string,fresh
          "A live reservation exists, so the claim must not be treated as abandoned.",string,blocked_by_active_reservation
          "The claim has crossed the stale threshold and no active reservation was\nfound in a supplied snapshot.",string,stale_candidate
          The claim has crossed a more conservative abandoned threshold.,string,abandoned_likely
          "The claim is old enough to inspect, but no Agent Mail snapshot was\nsupplied.",string,no_mail_snapshot
          Evidence conflicts or cannot be trusted.,string,ambiguous
      RecommendedAction:
        description: Suggested next action for an operator or agent.
        oneOf[5]{description,type,const}:
          Do nothing except continue normal observation.,string,observe
          Ask the assignee or human operator before touching the claim.,string,ask_owner
          Inspect Agent Mail reservations or capture a fresh snapshot.,string,inspect_mail
          "The issue is a candidate for the documented audit-comment plus claim\nsequence. This is still advisory, not an automatic mutation.",string,reclaim_candidate
          Leave the claim alone because evidence says work may still be active.,string,leave_active
      CoordinationEvidenceSource:
        description: Evidence categories present in a claim assessment.
        oneOf[4]{description,type,const}:
          "Issue status, assignee, and updated timestamp.",string,issue_metadata
          Owner-specific stale and abandoned thresholds.,string,policy_threshold
          A caller-supplied Agent Mail snapshot.,string,agent_mail_snapshot
          Explicit absence of an Agent Mail snapshot.,string,no_agent_mail_snapshot
      CoordinationSuggestedCommand:
        description: A command suggestion emitted for an operator to review and run manually.
        type: object
        properties:
          purpose:
            "$ref": #/$defs/CoordinationSuggestedCommandPurpose
          command.type: string
        required[2]: purpose,command
      CoordinationSuggestedCommandPurpose:
        description: Role for a suggested coordination command.
        oneOf[2]{description,type,const}:
          Record the reclaim evidence before touching ownership.,string,add_reclaim_audit_comment
          Claim the issue after the audit comment is recorded.,string,claim_issue
  CountGroup:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: CountGroup
    description: "Row emitted inside `br count --by <field> --json` under `groups[]`.\n\nKeep this in sync with `cli::commands::count::CountGroup`."
    type: object
    properties:
      group:
        description: "Group label, for example a status, priority, type, assignee, or label."
        type: string
      count:
        description: Number of matching issues in this group.
        type: integer
        format: uint
        minimum: 0
    required[2]: group,count
  ErrorEnvelope:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: ErrorEnvelope
    type: object
    properties:
      error:
        "$ref": #/$defs/ErrorBody
    required[1]: error
    "$defs":
      ErrorBody:
        type: object
        properties:
          code:
            description: Machine-readable error code (SCREAMING_SNAKE_CASE)
            type: string
          message:
            description: Human-readable message
            type: string
          hint:
            description: Optional hint for remediation
            type[2]: string,"null"
          retryable:
            description: Whether the operation can be retried
            type: boolean
          context.description: Additional context for debugging (arbitrary JSON)
        required[3]: code,message,retryable
  Issue:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: Issue
    description: The primary issue entity.
    type: object
    properties:
      id:
        description: "Unique ID (e.g., \"bd-abc123\")."
        type: string
      title:
        description: Title (1-500 chars).
        type: string
      description:
        description: Detailed description.
        type[2]: string,"null"
      design:
        description: Technical design notes.
        type[2]: string,"null"
      acceptance_criteria:
        description: Acceptance criteria.
        type[2]: string,"null"
      notes:
        description: Additional notes.
        type[2]: string,"null"
      status:
        description: Workflow status.
        "$ref": #/$defs/Status
        default: open
      priority:
        description: "Priority (0=Critical, 4=Backlog)."
        "$ref": #/$defs/Priority
        default: 2
      issue_type:
        description: "Issue type (bug, feature, etc.)."
        "$ref": #/$defs/IssueType
        default: task
      assignee:
        description: Assigned user.
        type[2]: string,"null"
      owner:
        description: Issue owner.
        type[2]: string,"null"
      estimated_minutes:
        description: Estimated effort in minutes.
        type[2]: integer,"null"
        format: int32
      created_at:
        description: Creation timestamp.
        type: string
        format: date-time
      created_by:
        description: Creator username.
        type[2]: string,"null"
      updated_at:
        description: Last update timestamp.
        type: string
        format: date-time
      closed_at:
        description: Closure timestamp.
        type[2]: string,"null"
        format: date-time
      close_reason:
        description: Reason for closure.
        type[2]: string,"null"
      closed_by_session:
        description: Session ID that closed this issue.
        type[2]: string,"null"
      due_at:
        description: Due date.
        type[2]: string,"null"
        format: date-time
      defer_until:
        description: Defer until date.
        type[2]: string,"null"
        format: date-time
      external_ref:
        description: "External reference (e.g., JIRA-123)."
        type[2]: string,"null"
      source_system:
        description: Source system for imported issues.
        type[2]: string,"null"
      source_repo:
        description: "Source repository for multi-repo support — basename of the\ncanonicalized parent of `.beads/`. Stable across clones of the\nsame repo on different machines (different absolute paths\nproduce the same basename). See [`canonical_source_repo`] in\n`cli::commands::create`."
        type[2]: string,"null"
      source_repo_path:
        description: "Absolute canonical path of the source repository. Distinct from\n`source_repo`: this field uniquely identifies the workspace on\nthe machine that produced the issue, which is what multi-repo\nfleet automation needs to route beads back to the right\ndirectory (see beads_rust#289). Two clones of the same repo\nunder `~/Developer/foo` vs `~/Developer/scratch/foo` collide on\n`source_repo` but disagree here. Optional — older databases and\nhand-edited JSONL records without this field are valid."
        type[2]: string,"null"
      agent_context:
        description: "Canonical-JSON governing instructions inherited by descendant\nbeads (beads_rust#297). When set on an ancestor and the project\nhas `inherited_context.enabled = true` in `.beads/config.yaml`,\n`br update --status in_progress` / `--claim` and `br show` emit\nthe ancestor's `agent_context` alongside the child's normal\noutput so the working agent sees the constraints regardless of\ncontext compaction or cold-start lookups.\n\nStorage: TEXT column holding a JSON document (typically an\nobject with `skills`, `constraints`, `references`, `workflow`,\n`metadata` fields, but the schema is intentionally open).\n`None` means \"no inherited context\"; emission for descendants\nsilently skips ancestors with `None` (no error, no noise).\n\nNot displayed in `br list` / `br search` — this is per-bead\ngovernance metadata, not browsable content."
        type[2]: string,"null"
      deleted_at:
        type[2]: string,"null"
        format: date-time
      deleted_by.type[2]: string,"null"
      delete_reason.type[2]: string,"null"
      original_type.type[2]: string,"null"
      compaction_level:
        type[2]: integer,"null"
        format: int32
        default: 0
      compacted_at:
        type[2]: string,"null"
        format: date-time
      compacted_at_commit.type[2]: string,"null"
      original_size:
        type[2]: integer,"null"
        format: int32
      sender.type[2]: string,"null"
      ephemeral.type: boolean
      pinned.type: boolean
      is_template.type: boolean
      labels:
        type: array
        items.type: string
      dependencies:
        type: array
        items:
          "$ref": #/$defs/Dependency
      comments:
        type: array
        items:
          "$ref": #/$defs/Comment
    required[4]: id,title,created_at,updated_at
    "$defs":
      Status:
        description: Issue lifecycle status.
        anyOf[2]:
          - type: string
            enum[8]: open,in_progress,blocked,deferred,draft,closed,tombstone,pinned
          - type: string
      Priority:
        description: "Issue priority (0=Critical, 4=Backlog)."
        type: integer
        format: int32
      IssueType:
        description: Issue type category.
        anyOf[2]:
          - type: string
            enum[7]: task,bug,feature,epic,chore,docs,question
          - type: string
      Dependency:
        description: Relationship between two issues.
        type: object
        properties:
          issue_id:
            description: The issue that has the dependency (source).
            type: string
          depends_on_id:
            description: The issue being depended on (target).
            type: string
          type:
            description: Type of dependency.
            "$ref": #/$defs/DependencyType
          created_at:
            description: Creation timestamp.
            type: string
            format: date-time
          created_by:
            description: Creator.
            type[2]: string,"null"
          metadata:
            description: Optional metadata (JSON).
            type[2]: string,"null"
          thread_id:
            description: Thread ID for conversation linking.
            type[2]: string,"null"
        required[4]: issue_id,depends_on_id,type,created_at
      DependencyType:
        description: Dependency relationship type.
        anyOf[2]:
          - type: string
            enum[11]: blocks,parent-child,conditional-blocks,waits-for,related,discovered-from,replies-to,relates-to,duplicates,supersedes,caused-by
          - type: string
      Comment:
        description: A comment on an issue.
        type: object
        properties:
          id:
            type: integer
            format: int64
          issue_id.type: string
          author.type: string
          text.type: string
          created_at:
            type: string
            format: date-time
        required[5]: id,issue_id,author,text,created_at
  IssueDetails:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
