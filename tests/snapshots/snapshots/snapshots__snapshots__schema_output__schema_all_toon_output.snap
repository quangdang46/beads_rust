  ReadyIssue:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: ReadyIssue
    description: "Minimal issue output for ready command (bd parity).\n\nContains only the fields that bd's ready command outputs.\nDoes NOT include: `compaction_level`, `original_size`, `dependency_count`, `dependent_count`"
    type: object
    properties:
      acceptance_criteria.type[2]: string,"null"
      assignee.type[2]: string,"null"
      created_at:
        type: string
        format: date-time
      created_by.type[2]: string,"null"
      description.type[2]: string,"null"
      estimated_minutes:
        type[2]: integer,"null"
        format: int32
      id.type: string
      issue_type:
        "$ref": #/$defs/IssueType
      labels:
        description: "Labels attached to the issue.\n\nAlways emitted (as `[]` when empty) so downstream consumers can filter\n`br ready --json` output on labels the same way they filter\n`br list --json` (#309)."
        type: array
        items.type: string
      notes.type[2]: string,"null"
      owner.type[2]: string,"null"
      priority:
        "$ref": #/$defs/Priority
      status:
        "$ref": #/$defs/Status
      title.type: string
      updated_at:
        type: string
        format: date-time
    required[8]: created_at,id,issue_type,labels,priority,status,title,updated_at
    "$defs":
      IssueType:
        description: Issue type category.
        anyOf[2]:
          - type: string
            enum[7]: task,bug,feature,epic,chore,docs,question
          - type: string
      Priority:
        description: "Issue priority (0=Critical, 4=Backlog)."
        type: integer
        format: int32
      Status:
        description: Issue lifecycle status.
        anyOf[2]:
          - type: string
            enum[8]: open,in_progress,blocked,deferred,draft,closed,tombstone,pinned
          - type: string
  StaleIssue:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: StaleIssue
    description: "Minimal issue output for stale command (bd parity).\nContains only the fields that bd's stale command outputs."
    type: object
    properties:
      created_at:
        type: string
        format: date-time
      id.type: string
      issue_type:
        "$ref": #/$defs/IssueType
      priority:
        "$ref": #/$defs/Priority
      status:
        "$ref": #/$defs/Status
      title.type: string
      updated_at:
        type: string
        format: date-time
      assignee.type[2]: string,"null"
    required[7]: created_at,id,issue_type,priority,status,title,updated_at
    "$defs":
      IssueType:
        description: Issue type category.
        anyOf[2]:
          - type: string
            enum[7]: task,bug,feature,epic,chore,docs,question
          - type: string
      Priority:
        description: "Issue priority (0=Critical, 4=Backlog)."
        type: integer
        format: int32
      Status:
        description: Issue lifecycle status.
        anyOf[2]:
          - type: string
            enum[8]: open,in_progress,blocked,deferred,draft,closed,tombstone,pinned
          - type: string
  Statistics:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: Statistics
    description: Aggregate statistics output.
    type: object
    properties:
      summary:
        "$ref": #/$defs/StatsSummary
      breakdowns:
        type: array
        items:
          "$ref": #/$defs/Breakdown
      recent_activity.anyOf[2]:
        - "$ref": #/$defs/RecentActivity
        - type: "null"
    required[2]: summary,breakdowns
    "$defs":
      StatsSummary:
        description: Summary statistics for the project.
        type: object
        properties:
          total_issues:
            type: integer
            format: uint
            minimum: 0
          open_issues:
            type: integer
            format: uint
            minimum: 0
          in_progress_issues:
            type: integer
            format: uint
            minimum: 0
          closed_issues:
            type: integer
            format: uint
            minimum: 0
          blocked_issues:
            type: integer
            format: uint
            minimum: 0
          deferred_issues:
            type: integer
            format: uint
            minimum: 0
          draft_issues:
            type: integer
            format: uint
            minimum: 0
          ready_issues:
            type: integer
            format: uint
            minimum: 0
          tombstone_issues:
            type: integer
            format: uint
            minimum: 0
          pinned_issues:
            type: integer
            format: uint
            minimum: 0
          epics_eligible_for_closure:
            type: integer
            format: uint
            minimum: 0
          average_lead_time_hours:
            type[2]: number,"null"
            format: double
        required[11]: total_issues,open_issues,in_progress_issues,closed_issues,blocked_issues,deferred_issues,draft_issues,ready_issues,tombstone_issues,pinned_issues,epics_eligible_for_closure
      Breakdown:
        description: Breakdown statistics by a dimension.
        type: object
        properties:
          dimension.type: string
          counts:
            type: array
            items:
              "$ref": #/$defs/BreakdownEntry
        required[2]: dimension,counts
      BreakdownEntry:
        description: A single entry in a breakdown.
        type: object
        properties:
          key.type: string
          count:
            type: integer
            format: uint
            minimum: 0
        required[2]: key,count
      RecentActivity:
        description: Recent activity statistics from git history.
        type: object
        properties:
          hours_tracked:
            type: integer
            format: uint32
            minimum: 0
          commit_count:
            type: integer
            format: uint
            minimum: 0
          issues_created:
            type: integer
            format: uint
            minimum: 0
          issues_closed:
            type: integer
            format: uint
            minimum: 0
          issues_updated:
            type: integer
            format: uint
            minimum: 0
          issues_reopened:
            type: integer
            format: uint
            minimum: 0
          total_changes:
            type: integer
            format: uint
            minimum: 0
        required[7]: hours_tracked,commit_count,issues_created,issues_closed,issues_updated,issues_reopened,total_changes
  TreeNode:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: TreeNode
    description: "Row emitted by `br dep tree --json`.\n\nKeep this in sync with `cli::commands::dep::TreeNode`. The command emits a\ncompact traversal node, not the older `format::output::TreeNode` shape that\nflattened a full `Issue`."
    type: object
    properties:
      id:
        description: "Stable issue ID, external dependency ID, or missing-issue placeholder ID."
        type: string
      title:
        description: Human-readable title used in text/tree output.
        type: string
      depth:
        description: Depth from the requested root issue. The root is depth 0.
        type: integer
        format: uint
        minimum: 0
      parent_id:
        description: "Parent node issue ID, or null for the root."
        type[2]: string,"null"
      priority:
        description: Numeric issue priority used for sibling sorting.
        type: integer
        format: int32
      status:
        description: "Issue status string, or synthesized status for external/missing nodes."
        type: string
      truncated:
        description: True when the node has children omitted by `--max-depth`.
        type: boolean
    required[6]: id,title,depth,priority,status,truncated
commands:
  blocked:
    shape: array
    jq_filter: ".[]"
    items_at: .
    item_schema: BlockedIssue
    error_envelope_on_stderr: false
  capabilities:
    shape: object
    jq_filter: .
    error_envelope_on_stderr: false
    notes: "Machine-readable command, feature, safety, exit-code, and env-var inventory."
  "comments list":
    shape: array
    jq_filter: ".[]"
    items_at: .
    error_envelope_on_stderr: true
    notes: Empty array if no comments. ErrorEnvelope on stderr if the issue id cannot be resolved.
  "coordination status":
    shape: object
    jq_filter: ".claims[]"
    items_at: .claims
    item_schema: CoordinationClaimRow
    error_envelope_on_stderr: false
    notes: "Read-only object with workspace summary and `claims[]` rows. The full envelope schema is `CoordinationStatusOutput`."
  count:
    shape: object
    jq_filter: .count
    error_envelope_on_stderr: false
    notes: Ungrouped `br count --json`; scalar count under `.count`. Grouped variants use the `count --by` entry.
  "count --by":
    shape: object
    jq_filter: ".groups[]"
    items_at: .groups
    item_schema: CountGroup
    error_envelope_on_stderr: false
    notes: For `br count --by <status|priority|type|assignee|label> --json`. The wrapper object also includes `total`.
  "dep list":
    shape: array
    jq_filter: ".[]"
    items_at: .
    error_envelope_on_stderr: true
  "dep tree":
    shape: array
    jq_filter: ".[]"
    items_at: .
    item_schema: TreeNode
    error_envelope_on_stderr: true
    notes: Pre-order traversal; each node carries a `depth` field.
  info:
    shape: object
    jq_filter: .
    error_envelope_on_stderr: false
    notes: "Workspace info object (paths, mode, config snapshot)."
  "label list":
    shape: array
    jq_filter: ".[]"
    items_at: .
    error_envelope_on_stderr: false
  list:
    shape: object
    jq_filter: ".issues[]"
    items_at: .issues
    item_schema: IssueWithCounts
    error_envelope_on_stderr: false
    notes: "Wrapper object with pagination metadata; iterate with `.issues[]`. The wrapper exists so totals/cursors can ride alongside the rows."
  ready:
    shape: array
    jq_filter: ".[]"
    items_at: .
    item_schema: ReadyIssue
    error_envelope_on_stderr: false
  "robot-docs guide":
    shape: object
    jq_filter: .
    error_envelope_on_stderr: false
    notes: JSON/TOON modes wrap the concise agent guide; text mode prints the guide directly.
  search:
    shape: array
    jq_filter: ".[]"
    items_at: .
    item_schema: IssueWithCounts
    error_envelope_on_stderr: false
  show:
    shape: array
    jq_filter: ".[0]"
    items_at: .
    item_schema: IssueDetails
    error_envelope_on_stderr: true
    notes: "Always a single-element array on success (wrapped for shape consistency with list-style commands). On a missing id, an ErrorEnvelope is written to stderr and exit code is non-zero."
  stale:
    shape: array
    jq_filter: ".[]"
    items_at: .
    item_schema: StaleIssue
    error_envelope_on_stderr: false
  stats:
    shape: object
    jq_filter: .
    item_schema: Statistics
    error_envelope_on_stderr: false
    notes: Single aggregate object.
  status:
    shape: object
    jq_filter: .
    item_schema: Statistics
    error_envelope_on_stderr: false
    notes: Alias for `stats` — identical envelope.
